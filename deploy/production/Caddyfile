{$API_SITE_ADDRESS} {
	route {
		encode gzip

		header {
			Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
			X-Content-Type-Options "nosniff"
			Referrer-Policy "no-referrer"
		}

		reverse_proxy /health api:8001

		reverse_proxy /api/* api:8001

		respond "World Cup Prediction API" 200
	}
}
