API_SITE_ADDRESS=api.worldcupai-mu.cn, static.worldcupai-mu.cn, worldcupai-mu.cn
TLS_EMAIL=
ALLOWED_ORIGINS=https://servicewechat.com,http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:5174,http://localhost:5174
