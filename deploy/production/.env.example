POSTGRES_PASSWORD=replace-with-strong-database-password
ADMIN_TOKEN=replace-with-strong-admin-token
APP_VERSION=0.1.0
CACHE_TTL_SECONDS=300
API_IMAGE=worldcup-api:20260624-dockerized

